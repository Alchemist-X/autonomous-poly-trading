# Shared settings
NODE_ENV=development
ENV_FILE=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/autopoly
DATABASE_READONLY_URL=postgres://postgres:postgres@localhost:5432/autopoly
REDIS_URL=redis://localhost:6379
APP_URL=http://localhost:3000

# Web site
ADMIN_PASSWORD=change-me
ORCHESTRATOR_INTERNAL_URL=http://localhost:4001
ORCHESTRATOR_INTERNAL_TOKEN=replace-me

# Executor
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
SIGNATURE_TYPE=1
POLYMARKET_HOST=https://clob.polymarket.com
CHAIN_ID=137
DEFAULT_ORDER_TYPE=FOK

# Orchestrator schedules and hard risk limits
AGENT_POLL_CRON=0 */4 * * *
SYNC_INTERVAL_SECONDS=30
BACKTEST_CRON=10 0 * * *
RESOLUTION_BASE_INTERVAL_MINUTES=60
RESOLUTION_URGENT_INTERVAL_MINUTES=15
DRAWDOWN_STOP_PCT=0.2
POSITION_STOP_LOSS_PCT=0.3
MAX_TOTAL_EXPOSURE_PCT=0.5
MAX_POSITIONS=10
MAX_TRADE_PCT=0.05
INITIAL_BANKROLL_USD=10000

# Orchestrator runtime
AGENT_RUNTIME_PROVIDER=codex
ARTIFACT_STORAGE_ROOT=runtime-artifacts
PROVIDER_TIMEOUT_SECONDS=90

# Pulse storage and market discovery
PULSE_SOURCE_REPO=all-polymarket-skill
PULSE_SOURCE_REPO_DIR=vendor/repos/all-polymarket-skill
PULSE_FETCH_TIMEOUT_SECONDS=60
PULSE_PAGES=1
PULSE_EVENTS_PER_PAGE=20
PULSE_MIN_LIQUIDITY_USD=5000
PULSE_MAX_CANDIDATES=12
PULSE_MIN_TRADEABLE_CANDIDATES=5
PULSE_MAX_AGE_MINUTES=30
PULSE_MAX_MARKDOWN_CHARS=24000

# Codex provider
CODEX_COMMAND=
CODEX_MODEL=
CODEX_SKILL_ROOT_DIR=vendor/repos/all-polymarket-skill
CODEX_SKILL_LOCALE=zh
CODEX_SKILLS=polymarket-market-pulse,portfolio-review-polymarket,poly-position-monitor,poly-resolution-tracking,api-trade-polymarket

# OpenClaw provider
OPENCLAW_COMMAND=
OPENCLAW_MODEL=
OPENCLAW_SKILL_ROOT_DIR=vendor/repos/all-polymarket-skill
OPENCLAW_SKILL_LOCALE=zh
OPENCLAW_SKILLS=polymarket-market-pulse,portfolio-review-polymarket,poly-position-monitor,poly-resolution-tracking,api-trade-polymarket
